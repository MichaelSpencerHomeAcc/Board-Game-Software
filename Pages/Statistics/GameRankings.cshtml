@page "{id:long?}"
@model Board_Game_Software.Pages.Statistics.GameRankingsModel
@{
    ViewData["Title"] = "Game Rankings";
}

<style>
    .rankings-shell { max-width: 1320px; }
    .rankings-header, .ranking-card, .rankings-table-wrap {
        border: 1px solid var(--bs-border-color);
        border-radius: 8px;
        background: var(--bs-body-tertiary);
    }
    .game-cover { width: 118px; height: 118px; border-radius: 8px; object-fit: cover; background: var(--bs-secondary-bg); }
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: .75rem; }
    .summary-item { border: 1px solid var(--bs-border-color); border-radius: 8px; background: var(--bs-body-bg); }
    .summary-value { font-size: 1.85rem; font-weight: 900; line-height: 1; }
    .podium-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
    .podium-card { border: 1px solid var(--bs-border-color); border-radius: 8px; background: var(--bs-body-bg); overflow: hidden; }
    .podium-rank { font-size: 2.5rem; font-weight: 900; line-height: 1; }
    .player-avatar { width: 54px; height: 54px; border-radius: 50%; object-fit: cover; background: var(--bs-secondary-bg); }
    .ranking-table td, .ranking-table th { white-space: nowrap; }
    .ranking-table .player-cell { white-space: normal; min-width: 220px; }
    @@media (max-width: 767.98px) {
        .rankings-header-inner { align-items: flex-start !important; }
        .game-cover { width: 84px; height: 84px; }
        .podium-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="container-fluid py-4 rankings-shell">
    <div class="rankings-header p-4 mb-4">
        <form method="get" class="d-flex flex-column flex-md-row gap-2 mb-4">
            <select asp-for="SelectedGameId" asp-items="Model.GameList" class="form-select">
                <option value="">Choose a point-scoring game...</option>
            </select>
            <button class="btn btn-primary px-4" type="submit">
                <i class="bi bi-trophy me-1"></i> Load Rankings
            </button>
        </form>

        @if (Model.SelectedGameId.HasValue)
        {
            <div class="d-flex rankings-header-inner align-items-center gap-3">
                <img src="/media/boardgame/front/@Model.Game.Gid" class="game-cover" alt="@Model.Game.BoardGameName cover" />
                <div class="min-w-0">
                    <h1 class="fw-bold mb-1 text-truncate">@Model.Game.BoardGameName</h1>
                    <div class="text-secondary">
                        @(Model.Game.FkBgdPublisherNavigation?.PublisherName ?? "Unknown publisher") leaderboard
                    </div>
                    <div class="small text-secondary mt-1">
                        Last played: @(Model.Summary.LastPlayed?.ToString("dd MMM yyyy") ?? "No completed plays")
                    </div>
                </div>
            </div>
        }
        else
        {
            <h1 class="fw-bold mb-1">Game Rankings</h1>
            <div class="text-secondary">Pick a point-scoring game to see the current leaderboard.</div>
        }
    </div>

    @if (Model.SelectedGameId.HasValue)
    {
        <div class="summary-grid mb-4">
            <div class="summary-item p-3">
                <div class="text-secondary small text-uppercase fw-bold">Leader</div>
                <div class="fw-bold fs-5 text-truncate">@Model.Summary.LeaderName</div>
            </div>
            <div class="summary-item p-3">
                <div class="text-secondary small text-uppercase fw-bold">Best Score</div>
                <div class="summary-value">@Model.Summary.BestScore.ToString("N0")</div>
            </div>
            <div class="summary-item p-3">
                <div class="text-secondary small text-uppercase fw-bold">Players Ranked</div>
                <div class="summary-value">@Model.Summary.PlayersRanked</div>
            </div>
            <div class="summary-item p-3">
                <div class="text-secondary small text-uppercase fw-bold">Scores Recorded</div>
                <div class="summary-value">@Model.Summary.ScoresRecorded</div>
            </div>
            <div class="summary-item p-3">
                <div class="text-secondary small text-uppercase fw-bold">Average Score</div>
                <div class="summary-value">@Model.Summary.AverageScore.ToString("N0")</div>
            </div>
        </div>

        @if (Model.Leaderboard.Any())
        {
            <div class="podium-grid mb-4">
                @foreach (var entry in Model.Leaderboard.Take(3).Select((value, index) => new { value, rank = index + 1 }))
                {
                    <article class="podium-card p-3">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                            <div>
                                <div class="podium-rank @(entry.rank == 1 ? "text-warning" : "text-secondary")">#@entry.rank</div>
                                <div class="text-secondary small text-uppercase fw-bold">Position</div>
                            </div>
                            <img src="/media/player/@entry.value.PlayerGid" class="player-avatar" alt="@entry.value.PlayerName" />
                        </div>
                        <h2 class="h5 fw-bold mb-1 text-truncate">@entry.value.PlayerName</h2>
                        <div class="fs-4 fw-bold text-info">@entry.value.Score.ToString("N0")</div>
                        <div class="small text-secondary">@entry.value.Plays play@(entry.value.Plays == 1 ? "" : "s") · avg @entry.value.AverageScore.ToString("N0")</div>
                    </article>
                }
            </div>

            <section class="rankings-table-wrap p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 fw-bold mb-0">Full Leaderboard</h2>
                    <span class="badge rounded-pill text-bg-secondary">@Model.Leaderboard.Count players</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle ranking-table mb-0">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th class="player-cell">Player</th>
                                <th class="text-end">Best Score</th>
                                <th class="text-end">Average</th>
                                <th class="text-end">Plays</th>
                                <th class="text-end">Date Set</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model.Leaderboard.Select((value, index) => new { value, rank = index + 1 }))
                            {
                                <tr>
                                    <td class="fw-bold">#@entry.rank</td>
                                    <td class="player-cell">
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="/media/player/@entry.value.PlayerGid" class="player-avatar" alt="@entry.value.PlayerName" />
                                            <span class="fw-semibold">@entry.value.PlayerName</span>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold">@entry.value.Score.ToString("N0")</td>
                                    <td class="text-end">@entry.value.AverageScore.ToString("N0")</td>
                                    <td class="text-end">@entry.value.Plays</td>
                                    <td class="text-end text-secondary">@(entry.value.Date?.ToString("dd MMM yyyy") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
        else
        {
            <div class="ranking-card p-5 text-center text-secondary">
                No completed point scores have been recorded for this game yet.
            </div>
        }
    }
</div>
