@page
@model Board_Game_Software.Pages.Admin.Clubs.IndexModel
@{
    ViewData["Title"] = "Clubs";
}

<div class="container py-4 admin-shell">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3 mb-4">
        <div>
            <h1 class="fw-bold mb-1">Club Accounts</h1>
            <div class="text-secondary">Manage tenant accounts, ownership, and each club's working data.</div>
        </div>
        <a asp-page="/Admin/ManageUsers/Index" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-people me-1"></i> Users
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success rounded-4">@Model.StatusMessage</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger rounded-4"></div>
    }

    <section class="club-admin-summary" aria-label="Club account summary">
        <div class="club-summary-tile">
            <span>Total</span>
            <strong>@Model.Summary.TotalClubs</strong>
        </div>
        <div class="club-summary-tile">
            <span>Public clubs</span>
            <strong>@Model.Summary.PublicClubs</strong>
        </div>
        <div class="club-summary-tile">
            <span>Private groups</span>
            <strong>@Model.Summary.PrivateGroups</strong>
        </div>
        <div class="club-summary-tile">
            <span>Hidden</span>
            <strong>@Model.Summary.HiddenClubs</strong>
        </div>
        <div class="club-summary-tile @(Model.Summary.ClubsNeedingOwner > 0 ? "needs-attention" : "")">
            <span>Need owner</span>
            <strong>@Model.Summary.ClubsNeedingOwner</strong>
        </div>
    </section>

    <section class="club-admin-layout mt-3">
        <details class="club-form-panel club-create-panel">
            <summary class="club-create-summary">
                <div>
                    <h2 class="h5 fw-bold mb-1">New Club Or Group</h2>
                    <div class="text-secondary small">Choose public club for discovery, or private group for home and friend circles.</div>
                </div>
                <span class="club-create-summary-icon">
                    <i class="bi bi-plus-lg"></i>
                </span>
            </summary>
            <form method="post" asp-page-handler="SaveClub" class="vstack gap-3">
                <div>
                    <label asp-for="Input.ClubName" class="form-label">Club name</label>
                    <input asp-for="Input.ClubName" class="form-control" maxlength="120" />
                </div>
                <div>
                    <label asp-for="Input.Slug" class="form-label">Slug</label>
                    <input asp-for="Input.Slug" class="form-control" maxlength="80" placeholder="auto-created if blank" />
                </div>
                <div>
                    <label asp-for="Input.Description" class="form-label">Description</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="3" maxlength="500"></textarea>
                </div>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="Input.ClubType" class="form-label">Club type</label>
                        <select asp-for="Input.ClubType" asp-items="Model.ClubTypeOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.Visibility" class="form-label">Visibility</label>
                        <select asp-for="Input.Visibility" asp-items="Model.VisibilityOptions" class="form-select"></select>
                    </div>
                </div>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="Input.DefaultGameNightVisibility" class="form-label">Default game night visibility</label>
                        <select asp-for="Input.DefaultGameNightVisibility" asp-items="Model.VisibilityOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.DefaultMatchVisibility" class="form-label">Default match visibility</label>
                        <select asp-for="Input.DefaultMatchVisibility" asp-items="Model.VisibilityOptions" class="form-select"></select>
                    </div>
                </div>
                <div class="row g-2">
                    <div class="col-md-4">
                        <div class="form-check">
                            <input asp-for="Input.IsDiscoverable" class="form-check-input" />
                            <label asp-for="Input.IsDiscoverable" class="form-check-label">Discoverable</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check">
                            <input asp-for="Input.AllowJoinRequests" class="form-check-input" />
                            <label asp-for="Input.AllowJoinRequests" class="form-check-label">Join requests</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check">
                            <input asp-for="Input.ShowStatsPublicly" class="form-check-input" />
                            <label asp-for="Input.ShowStatsPublicly" class="form-check-label">Public stats</label>
                        </div>
                    </div>
                </div>
                <div>
                    <label asp-for="Input.ContactEmail" class="form-label">Contact email</label>
                    <input asp-for="Input.ContactEmail" class="form-control" maxlength="256" />
                </div>
                <div>
                    <label asp-for="Input.VenueName" class="form-label">Venue</label>
                    <input asp-for="Input.VenueName" class="form-control" maxlength="160" />
                </div>
                <div>
                    <label asp-for="Input.VenueAddress" class="form-label">Venue address</label>
                    <textarea asp-for="Input.VenueAddress" class="form-control" rows="2" maxlength="300"></textarea>
                </div>
                <div class="row g-2">
                    <div class="col-6">
                        <label asp-for="Input.Latitude" class="form-label">Latitude</label>
                        <input asp-for="Input.Latitude" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label asp-for="Input.Longitude" class="form-label">Longitude</label>
                        <input asp-for="Input.Longitude" class="form-control" />
                    </div>
                </div>
                <div>
                    <label asp-for="Input.OwnerUserId" class="form-label">Owner login</label>
                    <select asp-for="Input.OwnerUserId" asp-items="Model.UserOptions" class="form-select">
                        <option value="">Assign owner later</option>
                    </select>
                </div>
                <div class="form-check">
                    <input asp-for="Input.CreateStarterShelf" class="form-check-input" />
                    <label asp-for="Input.CreateStarterShelf" class="form-check-label">Create starter shelf</label>
                </div>
                <button type="submit" class="btn btn-primary rounded-pill">
                    <i class="bi bi-plus-lg me-1"></i> Create club
                </button>
            </form>
        </details>

        <div class="club-list">
            <div class="club-list-toolbar">
                <div>
                    <h2 class="h5 fw-bold mb-1">Accounts</h2>
                    <div class="text-secondary small">Public clubs, private groups, and venue accounts in one place.</div>
                </div>
                <a asp-page="/Admin/ManageUsers/Index" class="btn btn-sm btn-outline-secondary rounded-pill">
                    <i class="bi bi-person-gear me-1"></i> Manage users
                </a>
            </div>
            @if (!Model.Clubs.Any())
            {
                <div class="empty-state border rounded-3 p-4 text-center">
                    <i class="bi bi-building display-5 text-secondary"></i>
                    <h2 class="h5 fw-bold mt-3">No clubs yet</h2>
                    <p class="text-secondary mb-0">Create your first club, then add yourself as Owner.</p>
                </div>
            }

            @foreach (var club in Model.Clubs)
            {
                <article class="club-card">
                    <div class="club-card-header">
                        <div class="min-w-0">
                            <h2 class="h4 fw-bold mb-1 text-truncate">@club.ClubName</h2>
                            <div class="text-secondary small text-truncate">
                                /@club.Slug
                                @if (club.Owners.Any())
                                {
                                    <span class="mx-1">·</span>
                                    <span>Owner: @string.Join(", ", club.Owners.Take(2))</span>
                                }
                            </div>
                        </div>
                        <span class="badge rounded-pill @(club.Owners.Any() ? "text-bg-success" : "text-bg-warning")">
                            @(club.Owners.Any() ? "Active account" : "Needs owner")
                        </span>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge rounded-pill text-bg-primary">@club.ClubTypeLabel</span>
                        <span class="badge rounded-pill @(club.Visibility == "public" ? "text-bg-success" : club.Visibility == "unlisted" ? "text-bg-secondary" : "text-bg-dark")">
                            @club.VisibilityLabel
                        </span>
                        <span class="badge rounded-pill @(club.IsDiscoverable ? "text-bg-info" : "text-bg-secondary")">
                            @(club.IsDiscoverable ? "Discoverable" : "Hidden from search")
                        </span>
                        <span class="badge rounded-pill @(club.AllowJoinRequests ? "text-bg-success" : "text-bg-secondary")">
                            @(club.AllowJoinRequests ? "Join requests" : "Invite/manual add")
                        </span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(club.Description))
                    {
                        <p class="text-secondary mb-3">@club.Description</p>
                    }

                    <div class="club-account-metrics mb-3">
                        <div class="club-account-metric">
                            <span class="metric-icon text-success"><i class="bi bi-people"></i></span>
                            <strong>@club.PlayerCount</strong>
                            <span>Players</span>
                        </div>
                        <div class="club-account-metric">
                            <span class="metric-icon text-primary"><i class="bi bi-dice-5"></i></span>
                            <strong>@club.BoardGameCount</strong>
                            <span>Games</span>
                        </div>
                        <div class="club-account-metric">
                            <span class="metric-icon text-info"><i class="bi bi-bookshelf"></i></span>
                            <strong>@club.ShelfCount</strong>
                            <span>Shelves</span>
                        </div>
                        <div class="club-account-metric">
                            <span class="metric-icon text-warning"><i class="bi bi-calendar-event"></i></span>
                            <strong>@club.GameNightCount</strong>
                            <span>Nights</span>
                        </div>
                    </div>

                    <div class="club-health mb-3">
                        <span class="club-health-chip @(club.HasContact ? "is-good" : "is-warning")">
                            <i class="bi @(club.HasContact ? "bi-check-circle" : "bi-exclamation-circle")"></i>
                            Contact
                        </span>
                        <span class="club-health-chip @(club.HasVenue ? "is-good" : "is-warning")">
                            <i class="bi @(club.HasVenue ? "bi-check-circle" : "bi-exclamation-circle")"></i>
                            Venue
                        </span>
                        <span class="club-health-chip @(club.HasMapLocation ? "is-good" : "is-muted")">
                            <i class="bi @(club.HasMapLocation ? "bi-geo-alt-fill" : "bi-geo-alt")"></i>
                            Map location
                        </span>
                        <span class="club-health-chip @(club.OpenGameNightCount > 0 ? "is-good" : "is-muted")">
                            <i class="bi bi-moon-stars"></i>
                            @club.OpenGameNightCount open night@(club.OpenGameNightCount == 1 ? "" : "s")
                        </span>
                    </div>

                    <div class="club-detail-grid mb-3">
                        <div>
                            <div class="small text-secondary text-uppercase fw-bold">Contact</div>
                            <div>@(club.ContactEmail ?? "Not set")</div>
                        </div>
                        <div>
                            <div class="small text-secondary text-uppercase fw-bold">Venue</div>
                            <div>@(club.VenueName ?? "Not set")</div>
                        </div>
                        <div>
                            <div class="small text-secondary text-uppercase fw-bold">Last game night</div>
                            <div>
                                @(club.LastGameNightDate?.ToString("dd MMM yyyy") ?? "No nights yet")
                            </div>
                        </div>
                        <div>
                            <div class="small text-secondary text-uppercase fw-bold">Defaults</div>
                            <div>Nights: @club.DefaultGameNightVisibilityLabel / Matches: @club.DefaultMatchVisibilityLabel</div>
                        </div>
                    </div>

                    <div class="club-account-actions mb-3">
                        <form method="post" asp-page="/Clubs/Switch">
                            <input type="hidden" name="ClubId" value="@club.Id" />
                            <input type="hidden" name="ReturnUrl" value="/DataSetup/Players/Add" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-person-plus me-1"></i> First player
                            </button>
                        </form>
                        <form method="post" asp-page="/Clubs/Switch">
                            <input type="hidden" name="ClubId" value="@club.Id" />
                            <input type="hidden" name="ReturnUrl" value="/Browsing/BoardGames/Index?templates=true" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-dice-5 me-1"></i> Import games
                            </button>
                        </form>
                        <form method="post" asp-page="/Clubs/Switch">
                            <input type="hidden" name="ClubId" value="@club.Id" />
                            <input type="hidden" name="ReturnUrl" value="/DataSetup/Shelves/Add" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-bookshelf me-1"></i> First shelf
                            </button>
                        </form>
                        <form method="post" asp-page="/Clubs/Switch">
                            <input type="hidden" name="ClubId" value="@club.Id" />
                            <input type="hidden" name="ReturnUrl" value="/GameNight/Index" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-calendar-check me-1"></i> Nights
                            </button>
                        </form>
                    </div>

                    <details class="club-edit mb-3">
                        <summary class="btn btn-outline-secondary btn-sm rounded-pill">
                            <i class="bi bi-pencil me-1"></i> Settings
                        </summary>
                        <form method="post" asp-page-handler="SaveClub" class="club-edit-form mt-3">
                            <input type="hidden" asp-for="Input.Id" value="@club.Id" />
                            <div class="club-settings-section">
                                <div class="club-settings-heading">Identity</div>
                                <div>
                                    <label class="form-label" for="club-name-@club.Id">Club name</label>
                                    <input id="club-name-@club.Id" name="Input.ClubName" value="@club.ClubName" class="form-control" maxlength="120" />
                                </div>
                                <div>
                                    <label class="form-label" for="club-slug-@club.Id">Slug</label>
                                    <input id="club-slug-@club.Id" name="Input.Slug" value="@club.Slug" class="form-control" maxlength="80" />
                                    <div class="form-text">Used in direct links. Lowercase letters, numbers and hyphens work best.</div>
                                </div>
                                <div class="club-settings-wide">
                                    <label class="form-label" for="club-description-@club.Id">Description</label>
                                    <textarea id="club-description-@club.Id" name="Input.Description" class="form-control" rows="2" maxlength="500">@club.Description</textarea>
                                </div>
                            </div>

                            <div class="club-settings-section">
                                <div class="club-settings-heading">Privacy And Access</div>
                                <div>
                                    <label class="form-label" for="club-type-@club.Id">Club type</label>
                                    <select id="club-type-@club.Id" name="Input.ClubType" class="form-select">
                                        @foreach (var type in Board_Game_Software.Models.ClubDefaults.ClubTypes)
                                        {
                                            <option value="@type" selected="@(type == club.ClubType)">@Board_Game_Software.Models.ClubDefaults.GetDisplayName(type)</option>
                                        }
                                    </select>
                                    <div class="form-text">Public clubs are for discovery. Private groups are for homes, friends and families.</div>
                                </div>
                                <div>
                                    <label class="form-label" for="club-visibility-@club.Id">Club visibility</label>
                                    <select id="club-visibility-@club.Id" name="Input.Visibility" class="form-select">
                                        @foreach (var visibility in Board_Game_Software.Models.ClubDefaults.VisibilityLevels)
                                        {
                                            <option value="@visibility" selected="@(visibility == club.Visibility)">@Board_Game_Software.Models.ClubDefaults.GetDisplayName(visibility)</option>
                                        }
                                    </select>
                                    <div class="form-text">Public appears openly. Unlisted uses direct links. Private is members-only.</div>
                                </div>
                                <div class="club-settings-checks">
                                    <div class="form-check">
                                        <input type="checkbox" name="Input.IsDiscoverable" value="true" class="form-check-input" checked="@club.IsDiscoverable" id="discoverable-@club.Id" />
                                        <input type="hidden" name="Input.IsDiscoverable" value="false" />
                                        <label class="form-check-label" for="discoverable-@club.Id">Show in public discovery</label>
                                    </div>
                                    <div class="form-check">
                                        <input type="checkbox" name="Input.AllowJoinRequests" value="true" class="form-check-input" checked="@club.AllowJoinRequests" id="join-requests-@club.Id" />
                                        <input type="hidden" name="Input.AllowJoinRequests" value="false" />
                                        <label class="form-check-label" for="join-requests-@club.Id">Allow join requests</label>
                                    </div>
                                    <div class="form-check">
                                        <input type="checkbox" name="Input.ShowStatsPublicly" value="true" class="form-check-input" checked="@club.ShowStatsPublicly" id="stats-public-@club.Id" />
                                        <input type="hidden" name="Input.ShowStatsPublicly" value="false" />
                                        <label class="form-check-label" for="stats-public-@club.Id">Allow public stats</label>
                                    </div>
                                </div>
                            </div>

                            <div class="club-settings-section">
                                <div class="club-settings-heading">Defaults</div>
                                <div>
                                    <label class="form-label" for="night-visibility-@club.Id">Game night visibility</label>
                                    <select id="night-visibility-@club.Id" name="Input.DefaultGameNightVisibility" class="form-select">
                                        @foreach (var visibility in Board_Game_Software.Models.ClubDefaults.VisibilityLevels)
                                        {
                                            <option value="@visibility" selected="@(visibility == club.DefaultGameNightVisibility)">@Board_Game_Software.Models.ClubDefaults.GetDisplayName(visibility)</option>
                                        }
                                    </select>
                                    <div class="form-text">Used when new scheduled game nights are created later.</div>
                                </div>
                                <div>
                                    <label class="form-label" for="match-visibility-@club.Id">Match visibility</label>
                                    <select id="match-visibility-@club.Id" name="Input.DefaultMatchVisibility" class="form-select">
                                        @foreach (var visibility in Board_Game_Software.Models.ClubDefaults.VisibilityLevels)
                                        {
                                            <option value="@visibility" selected="@(visibility == club.DefaultMatchVisibility)">@Board_Game_Software.Models.ClubDefaults.GetDisplayName(visibility)</option>
                                        }
                                    </select>
                                    <div class="form-text">Used when one-off matches and results are added later.</div>
                                </div>
                            </div>

                            <div class="club-settings-section">
                                <div class="club-settings-heading">Contact And Location</div>
                                <div>
                                    <label class="form-label" for="contact-email-@club.Id">Contact email</label>
                                    <input id="contact-email-@club.Id" name="Input.ContactEmail" value="@club.ContactEmail" class="form-control" maxlength="256" />
                                </div>
                                <div>
                                    <label class="form-label" for="venue-name-@club.Id">Venue name</label>
                                    <input id="venue-name-@club.Id" name="Input.VenueName" value="@club.VenueName" class="form-control" maxlength="160" />
                                </div>
                                <div class="club-settings-wide">
                                    <label class="form-label" for="venue-address-@club.Id">Venue address</label>
                                    <textarea id="venue-address-@club.Id" name="Input.VenueAddress" class="form-control" rows="2" maxlength="300">@club.VenueAddress</textarea>
                                </div>
                                <div>
                                    <label class="form-label" for="latitude-@club.Id">Latitude</label>
                                    <input id="latitude-@club.Id" name="Input.Latitude" value="@club.Latitude" class="form-control" />
                                </div>
                                <div>
                                    <label class="form-label" for="longitude-@club.Id">Longitude</label>
                                    <input id="longitude-@club.Id" name="Input.Longitude" value="@club.Longitude" class="form-control" />
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm rounded-pill">
                                <i class="bi bi-check-lg me-1"></i> Save
                            </button>
                        </form>
                    </details>

                    <div class="border-top pt-3">
                        <div class="d-flex justify-content-between align-items-center gap-3 mb-2">
                            <h3 class="h6 fw-bold mb-0">Members</h3>
                            <span class="badge text-bg-secondary rounded-pill">@club.Members.Count</span>
                        </div>

                        <div class="member-list mb-3">
                            @foreach (var member in club.Members)
                            {
                                <div class="member-row">
                                    <div class="min-w-0">
                                        <div class="fw-semibold text-truncate">@member.DisplayName</div>
                                        <div class="small text-secondary">@member.RoleLabel / @member.StatusLabel</div>
                                    </div>
                                    <form method="post" asp-page-handler="RemoveMember">
                                        <input type="hidden" asp-for="MembershipId" value="@member.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill" aria-label="Remove member">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>

                        <form method="post" asp-page-handler="AddMember" class="add-member-form">
                            <input type="hidden" asp-for="ClubId" value="@club.Id" />
                            <select asp-for="UserId" asp-items="Model.UserOptions" class="form-select form-select-sm">
                                <option value="">Registered user...</option>
                            </select>
                            <input asp-for="InvitedEmail" class="form-control form-control-sm" type="email" placeholder="invite@email.com" />
                            <input asp-for="GuestName" class="form-control form-control-sm" placeholder="Guest name" />
                            <select asp-for="MembershipRole" asp-items="Model.RoleOptions" class="form-select form-select-sm"></select>
                            <button type="submit" class="btn btn-outline-success btn-sm rounded-pill">
                                <i class="bi bi-person-plus me-1"></i> Add
                            </button>
                        </form>
                    </div>
                </article>
            }
        </div>
    </section>
</div>
