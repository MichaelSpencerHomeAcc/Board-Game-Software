@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<style>
    .home-shell {
        max-width: 1320px;
    }

    .home-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.75fr);
        gap: 1.5rem;
        align-items: stretch;
        padding: 2rem;
        border-bottom: 1px solid var(--bs-border-color);
    }

    .home-title {
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 1.02;
        font-weight: 900;
        margin: 0;
    }

    .home-scope {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        border: 1px solid var(--bs-border-color);
        border-radius: 999px;
        padding: 0.35rem 0.75rem;
        color: var(--bs-secondary-color);
        background: var(--bs-tertiary-bg);
        font-weight: 700;
        font-size: 0.85rem;
    }

    .home-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin-top: 1.5rem;
    }

    .home-panel,
    .stat-box,
    .recent-night {
        border: 1px solid var(--bs-border-color);
        border-radius: 8px;
        background: var(--bs-tertiary-bg);
    }

    .home-panel {
        padding: 1.25rem;
    }

    .stat-box {
        padding: 1.25rem;
        transition: border-color 0.16s ease, transform 0.16s ease, background-color 0.16s ease;
        text-decoration: none;
        display: block;
    }

    .stat-box:hover {
        background: rgba(var(--bs-primary-rgb), 0.08);
        border-color: rgba(var(--bs-primary-rgb), 0.65);
        transform: translateY(-2px);
    }

    .stat-icon {
        width: 2.7rem;
        height: 2.7rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
    }

    .stat-value {
        font-size: 2.25rem;
        line-height: 1;
        font-weight: 900;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .home-lower-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(300px, 0.45fr);
        gap: 1rem;
    }

    .recent-night {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 0.9rem 1rem;
        text-decoration: none;
        color: inherit;
    }

    .recent-night:hover {
        border-color: rgba(var(--bs-primary-rgb), 0.65);
        background: rgba(var(--bs-primary-rgb), 0.06);
    }

    .quick-action {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.85rem 0;
        color: inherit;
        text-decoration: none;
        border-bottom: 1px solid var(--bs-border-color);
    }

    .quick-action:last-child {
        border-bottom: 0;
    }

    .quick-action:hover {
        color: var(--bs-primary);
    }

    @@media (max-width: 991.98px) {
        .home-hero,
        .home-lower-grid {
            grid-template-columns: 1fr;
        }

        .dashboard-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 575.98px) {
        .home-hero {
            padding: 1rem 0 1.25rem;
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .home-actions .btn {
            width: 100%;
        }
    }
</style>

<div class="container-fluid py-4 home-shell">
    <section class="home-hero mb-4">
        <div>
            <div class="home-scope mb-3">
                <i class="bi bi-building"></i>
                @Model.ScopeName
            </div>
            <h1 class="home-title">Board Game Manager</h1>
            <p class="home-lead text-secondary mt-3 mb-0">@Model.ScopeDescription</p>
            <div class="home-actions">
                <a asp-page="/GameNight/Create" class="btn btn-primary btn-lg px-4">
                    <i class="bi bi-calendar-plus me-1"></i> Start Game Night
                </a>
                <a asp-page="/Browsing/BoardGames/Index" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="bi bi-dice-5 me-1"></i> Browse Library
                </a>
            </div>
        </div>

        <aside class="home-panel">
            <div class="text-secondary small text-uppercase fw-bold mb-2">Tonight Check</div>
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                <div>
                    <div class="fs-4 fw-bold">@Model.OpenGameNights open</div>
                    <div class="text-secondary">active or upcoming nights</div>
                </div>
                <i class="bi bi-moon-stars fs-1 text-primary"></i>
            </div>
            <a asp-page="/GameNight/Index" class="btn btn-sm btn-outline-primary w-100">View schedule</a>
        </aside>
    </section>

    <section class="dashboard-grid mb-4">
        <a asp-page="/Browsing/BoardGames/Index" class="stat-box">
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                <div class="stat-icon bg-primary bg-opacity-10">
                    <i class="bi bi-controller fs-4 text-primary"></i>
                </div>
                <i class="bi bi-arrow-right text-secondary"></i>
            </div>
            <div class="stat-value text-body">@Model.TotalGames</div>
            <div class="fw-bold text-body mt-2">Library</div>
            <div class="text-secondary small">board games in scope</div>
        </a>

        <a asp-page="/DataSetup/Players/Index" class="stat-box">
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                <div class="stat-icon bg-success bg-opacity-10">
                    <i class="bi bi-people fs-4 text-success"></i>
                </div>
                <i class="bi bi-arrow-right text-secondary"></i>
            </div>
            <div class="stat-value text-body">@Model.TotalPlayers</div>
            <div class="fw-bold text-body mt-2">Players</div>
            <div class="text-secondary small">registered competitors</div>
        </a>

        <a asp-page="/GameNight/Index" class="stat-box">
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                <div class="stat-icon bg-info bg-opacity-10">
                    <i class="bi bi-calendar-event fs-4 text-info"></i>
                </div>
                <i class="bi bi-arrow-right text-secondary"></i>
            </div>
            <div class="stat-value text-body">@Model.TotalGameNights</div>
            <div class="fw-bold text-body mt-2">Game Nights</div>
            <div class="text-secondary small">recorded sessions</div>
        </a>

        <a asp-page="/Statistics/Index" class="stat-box">
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                <div class="stat-icon bg-warning bg-opacity-10">
                    <i class="bi bi-trophy fs-4 text-warning"></i>
                </div>
                <i class="bi bi-arrow-right text-secondary"></i>
            </div>
            <div class="stat-value text-body">@Model.TotalMatches</div>
            <div class="fw-bold text-body mt-2">Matches</div>
            <div class="text-secondary small">linked to game nights</div>
        </a>
    </section>

    <section class="home-lower-grid">
        <div class="home-panel">
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                <div>
                    <h2 class="h5 fw-bold mb-1">Recent Game Nights</h2>
                    <div class="text-secondary small">Latest sessions for the current scope.</div>
                </div>
                <a asp-page="/GameNight/Index" class="btn btn-sm btn-outline-secondary">All nights</a>
            </div>

            @if (Model.RecentNights.Any())
            {
                <div class="d-grid gap-2">
                    @foreach (var night in Model.RecentNights)
                    {
                        <a asp-page="/GameNight/Details" asp-route-id="@night.Id" class="recent-night">
                            <div>
                                <div class="fw-bold">@night.Date.ToString("dd MMM yyyy")</div>
                                <div class="text-secondary small">@night.PlayerCount players · @night.MatchCount matches</div>
                            </div>
                            <span class="badge rounded-pill @(night.Finished ? "text-bg-secondary" : "text-bg-primary")">
                                @(night.Finished ? "Finished" : "Open")
                            </span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="text-secondary py-4 text-center">No game nights yet for this scope.</div>
            }
        </div>

        <aside class="home-panel">
            <h2 class="h5 fw-bold mb-1">Quick Actions</h2>
            <div class="text-secondary small mb-2">Common setup jobs.</div>
            <a asp-page="/GameNight/Create" class="quick-action">
                <span><i class="bi bi-calendar-plus me-2 text-primary"></i>Create game night</span>
                <i class="bi bi-chevron-right"></i>
            </a>
            <a asp-page="/DataSetup/Players/Add" class="quick-action">
                <span><i class="bi bi-person-plus me-2 text-success"></i>Add player</span>
                <i class="bi bi-chevron-right"></i>
            </a>
            <a asp-page="/Browsing/BoardGames/Index" class="quick-action">
                <span><i class="bi bi-dice-5 me-2 text-info"></i>Manage library</span>
                <i class="bi bi-chevron-right"></i>
            </a>
            <a asp-page="/Statistics/GameRankings" class="quick-action">
                <span><i class="bi bi-bar-chart me-2 text-warning"></i>View rankings</span>
                <i class="bi bi-chevron-right"></i>
            </a>
        </aside>
    </section>
</div>
