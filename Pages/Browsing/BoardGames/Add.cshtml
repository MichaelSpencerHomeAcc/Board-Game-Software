@page
@model Board_Game_Software.Pages.Browsing.BoardGames.AddModel
@{
    ViewData["Title"] = "Add New Board Game";
}

<style>
    /* Marker Pill Styles */
    .marker-pills-container {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        background: #1e2125;
        padding: 15px;
        border-radius: 8px;
        border: 1px solid #343a40;
        min-height: 100px;
    }

    .marker-pill {
        display: inline-flex;
        align-items: center;
        background: #ffffff;
        color: #000;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
        border: 1px solid #dee2e6;
    }

    .btn-remove-pill {
        background: none;
        border: none;
        color: #6c757d;
        margin-left: 8px;
        padding: 0;
        font-size: 1.1rem;
        line-height: 1;
        cursor: pointer;
    }

        .btn-remove-pill:hover {
            color: #dc3545;
        }

    /* Bulk Modal Styles */
    .bulk-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 12px;
        max-height: 400px;
        overflow-y: auto;
        padding: 10px;
    }

    .bulk-tile {
        cursor: pointer;
        border: 2px solid #343a40;
        border-radius: 8px;
        background: #212529;
        padding: 8px;
        text-align: center;
        transition: 0.2s;
        position: relative;
    }

        .bulk-tile:hover {
            border-color: #495057;
        }

        .bulk-tile.selected {
            border-color: #0d6efd;
            background: #0d6efd20;
        }

            .bulk-tile.selected::after {
                content: "\2713";
                position: absolute;
                top: 2px;
                right: 5px;
                color: #0d6efd;
                font-weight: bold;
            }

    .tile-img {
        height: 60px;
        object-fit: contain;
        margin-bottom: 5px;
        max-width: 100%;
    }

    .tile-text {
        font-size: 0.75rem;
        color: #fff;
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="Index" class="btn btn-outline-secondary me-3 shadow-sm">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="text-body m-0">Add New Board Game</h1>
    </div>

    <form method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="row">
            <div class="col-lg-8">
                <div class="card bg-dark text-white border-secondary mb-4 p-4 shadow-sm">
                    <h5 class="text-info mb-3">Core Details</h5>
                    <div class="mb-3">
                        <label asp-for="BoardGame.BoardGameName" class="form-label text-muted small">Game Name</label>
                        <input asp-for="BoardGame.BoardGameName" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Scythe" />
                    </div>

                    @if (Model.DuplicateCandidates.Any())
                    {
                        <div class="alert alert-warning border-warning mb-4">
                            <div class="fw-bold mb-2">
                                <i class="bi bi-exclamation-triangle me-1"></i> Possible existing games found
                            </div>
                            <div class="d-grid gap-2 mb-3">
                                @foreach (var candidate in Model.DuplicateCandidates)
                                {
                                    <a asp-page="./BoardGameDetails"
                                       asp-route-id="@candidate.Id"
                                       class="d-flex align-items-center gap-2 text-decoration-none text-body border border-warning-subtle rounded p-2">
                                        <img src="/media/boardgame/front/@candidate.Gid"
                                             alt="@candidate.Name cover"
                                             style="width:42px;height:42px;object-fit:cover;border-radius:6px;background:#111;" />
                                        <span class="flex-grow-1 min-w-0">
                                            <span class="fw-semibold d-block text-truncate">@candidate.Name</span>
                                            <span class="small text-secondary">
                                                @(candidate.PublisherName ?? "Publisher not set")
                                                · @(candidate.IsClubGame ? "Club library" : "Shared library")
                                            </span>
                                        </span>
                                        @if (candidate.IsExactMatch)
                                        {
                                            <span class="badge rounded-pill text-bg-warning">Exact</span>
                                        }
                                    </a>
                                }
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" asp-for="ConfirmAddDespiteMatches" />
                                <label class="form-check-label" asp-for="ConfirmAddDespiteMatches">
                                    Add this as a separate game anyway
                                </label>
                            </div>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label class="form-label text-muted small mb-0">Publisher</label>
                                <button type="button" class="btn btn-outline-info btn-sm py-0" data-bs-toggle="modal" data-bs-target="#quickPublisherModal">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </div>
                            <select asp-for="BoardGame.FkBgdPublisher" asp-items="Model.Publishers" class="form-select bg-dark text-white border-secondary">
                                <option value="">-- Select Publisher --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label class="form-label text-muted small mb-0">Game Type</label>
                                <button type="button" class="btn btn-outline-info btn-sm py-0" data-bs-toggle="modal" data-bs-target="#quickGameTypeModal">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </div>
                            <select asp-for="BoardGame.FkBgdBoardGameType" asp-items="Model.BoardGameTypes" class="form-select bg-dark text-white border-secondary">
                                <option value="">-- Select Type --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small">Victory Condition</label>
                            <select asp-for="BoardGame.FkBgdBoardGameVictoryConditionType" asp-items="Model.VictoryConditions" class="form-select bg-dark text-white border-secondary">
                                <option value="">-- Select Victory Condition --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small">Release Date</label>
                            <input asp-for="BoardGame.ReleaseDate" type="date" class="form-control bg-dark text-white border-secondary" />
                        </div>
                    </div>

                    <hr class="border-secondary my-4">
                    <h5 class="text-info mb-3">Gameplay & Physical Statistics</h5>
                    <div class="row mb-3">
                        <div class="col-md-3 mb-3"><label class="small text-muted">Min Players</label><input asp-for="BoardGame.PlayerCountMin" type="number" class="form-control bg-dark text-white border-secondary" /></div>
                        <div class="col-md-3 mb-3"><label class="small text-muted">Max Players</label><input asp-for="BoardGame.PlayerCountMax" type="number" class="form-control bg-dark text-white border-secondary" /></div>
                        <div class="col-md-3 mb-3"><label class="small text-muted">Min Time (m)</label><input asp-for="BoardGame.PlayingTimeMinInMinutes" type="number" class="form-control bg-dark text-white border-secondary" /></div>
                        <div class="col-md-3 mb-3"><label class="small text-muted">Max Time (m)</label><input asp-for="BoardGame.PlayingTimeMaxInMinutes" type="number" class="form-control bg-dark text-white border-secondary" /></div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4 mb-3">
                            <label class="small text-muted">Complexity Rating (1-5)</label>
                            <input asp-for="BoardGame.ComplexityRating" class="form-control bg-dark text-white border-secondary" placeholder="e.g. 3.25" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="small text-muted">Height (cm)</label>
                            <input asp-for="BoardGame.HeightCm" type="number" step="0.01" class="form-control bg-dark text-white border-secondary" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="small text-muted">Width (cm)</label>
                            <input asp-for="BoardGame.WidthCm" type="number" step="0.01" class="form-control bg-dark text-white border-secondary" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-warning small fw-bold"><i class="bi bi-graph-up-arrow me-2"></i>Algorithm (Elo Method)</label>
                        <select asp-for="SelectedEloMethodId" asp-items="Model.EloMethods" class="form-select bg-dark text-warning border-warning border-opacity-25">
                            <option value="">-- No Rating Logic (Social Only) --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small">How to Play (URL)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-secondary border-secondary text-white"><i class="bi bi-link-45deg"></i></span>
                            <input asp-for="BoardGame.HowToPlayHyperlink" class="form-control bg-dark text-white border-secondary" placeholder="https://youtube.com/..." />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small">Game Summary</label>
                        <textarea asp-for="BoardGame.BoardGameSummary" class="form-control bg-dark text-white border-secondary" rows="4" placeholder="Brief overview of the game theme and mechanics..."></textarea>
                    </div>

                    <hr class="border-secondary my-4">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" asp-for="BoardGame.IsExpansion" id="expansionSwitch">
                        <label class="form-check-label" for="expansionSwitch">This is an expansion</label>
                    </div>

                    <div id="expansionUI" class="mb-4" style="display: @(Model.BoardGame.IsExpansion ? "block" : "none")">
                        <label class="form-label text-muted small">Base Game(s)</label>
                        <select asp-for="ExpansionBaseGameIds" asp-items="Model.BaseGames" class="form-select bg-dark text-white border-secondary" multiple size="6"></select>
                        <div class="form-text text-muted">Hold Ctrl to select more than one base game.</div>
                    </div>

                    <hr class="border-secondary my-4">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" asp-for="BoardGame.HasMarkers" id="markerSwitch">
                        <label class="form-check-label" for="markerSwitch">Includes Markers/Components?</label>
                    </div>

                    <div id="markerUI" style="display: none;">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="small text-muted">Game Components</label>
                            <button type="button" class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#bulkModal">+ Add Multiple</button>
                        </div>
                        <div class="marker-pills-container" id="pillBox"></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card bg-dark text-white border-secondary mb-4">
                    <div class="card-header border-secondary"><h5>Visuals</h5></div>
                    <div class="card-body text-center">
                        <div class="mb-3 border border-secondary rounded p-2 bg-black" style="min-height: 250px; display: flex; align-items: center; justify-content: center;">
                            <img id="imgPrev" src="/images/no-thumb.png" class="img-fluid" style="max-height: 300px;" />
                        </div>
                        <input type="file" asp-for="ImageUpload" class="form-control form-control-sm bg-dark text-white border-secondary" accept=".jpg,.jpeg,.png,.webp" onchange="preview(this)" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success w-100 py-3 mb-2">Add Board Game</button>
                <a asp-page="./Index" class="btn btn-outline-secondary w-100">Cancel</a>
            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="quickPublisherModal" tabindex="-1" aria-labelledby="quickPublisherModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="quickPublisherModalLabel">Add Publisher</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label for="quickPublisherName" class="form-label text-muted small">Publisher Name</label>
                <input id="quickPublisherName" maxlength="80" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Stonemaier Games" />
                <div id="quickPublisherMessage" class="small mt-2"></div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-info" onclick="quickAddPublisher()">Add Publisher</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="quickGameTypeModal" tabindex="-1" aria-labelledby="quickGameTypeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="quickGameTypeModalLabel">Add Game Type</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label for="quickGameTypeName" class="form-label text-muted small">Game Type</label>
                <input id="quickGameTypeName" maxlength="50" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Worker placement" />
                <div id="quickGameTypeMessage" class="small mt-2"></div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-info" onclick="quickAddGameType()">Add Game Type</button>
            </div>
        </div>
    </div>
</div>

@* --- BULK MODAL --- *@
<div class="modal fade" id="bulkModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">Select Components</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="modalSearch" class="form-control bg-dark text-white border-secondary mb-3" placeholder="Search markers..." onkeyup="filterBulk()">
                <div class="bulk-container">
                    @foreach (var item in Model.AvailableMarkerTypes)
                    {
                        <div class="bulk-tile" data-id="@item.Id" data-name="@item.TypeDesc" onclick="toggleTile(this)">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="tile-img" />
                            }
                            <span class="tile-text">@item.TypeDesc</span>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-primary" onclick="commitBulk()" data-bs-dismiss="modal">Add Selected</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('markerSwitch').addEventListener('change', function() {
            document.getElementById('markerUI').style.display = this.checked ? 'block' : 'none';
        });

        document.getElementById('expansionSwitch').addEventListener('change', function() {
            document.getElementById('expansionUI').style.display = this.checked ? 'block' : 'none';
        });

        async function quickPost(handler, fields) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const response = await fetch(`?handler=${handler}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: new URLSearchParams(fields)
            });

            const payload = await response.json();
            if (!response.ok) {
                throw new Error(payload.message || 'Unable to add item.');
            }

            return payload;
        }

        function selectNewOption(selectName, item) {
            const select = document.querySelector(`select[name="${selectName}"]`);
            let option = Array.from(select.options).find(o => o.value === item.id.toString());
            if (!option) {
                option = new Option(item.name, item.id);
                select.add(option);
            }

            select.value = item.id;
        }

        async function quickAddPublisher() {
            const input = document.getElementById('quickPublisherName');
            const message = document.getElementById('quickPublisherMessage');
            message.className = 'small mt-2 text-muted';
            message.textContent = 'Adding...';

            try {
                const item = await quickPost('QuickAddPublisher', { publisherName: input.value });
                selectNewOption('BoardGame.FkBgdPublisher', item);
                input.value = '';
                message.textContent = '';
                bootstrap.Modal.getInstance(document.getElementById('quickPublisherModal')).hide();
            } catch (error) {
                message.className = 'small mt-2 text-danger';
                message.textContent = error.message;
            }
        }

        async function quickAddGameType() {
            const input = document.getElementById('quickGameTypeName');
            const message = document.getElementById('quickGameTypeMessage');
            message.className = 'small mt-2 text-muted';
            message.textContent = 'Adding...';

            try {
                const item = await quickPost('QuickAddGameType', { typeDesc: input.value });
                selectNewOption('BoardGame.FkBgdBoardGameType', item);
                input.value = '';
                message.textContent = '';
                bootstrap.Modal.getInstance(document.getElementById('quickGameTypeModal')).hide();
            } catch (error) {
                message.className = 'small mt-2 text-danger';
                message.textContent = error.message;
            }
        }

        function preview(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = e => document.getElementById('imgPrev').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }

        function toggleTile(el) { el.classList.toggle('selected'); }

        function filterBulk() {
            let val = document.getElementById('modalSearch').value.toLowerCase();
            document.querySelectorAll('.bulk-tile').forEach(t => {
                t.style.display = t.dataset.name.toLowerCase().includes(val) ? "block" : "none";
            });
        }

        function commitBulk() {
            const container = document.getElementById('pillBox');
            document.querySelectorAll('.bulk-tile.selected').forEach(t => {
                const id = t.dataset.id;
                const name = t.dataset.name;
                const pill = document.createElement('div');
                pill.className = 'marker-pill';
                pill.innerHTML = `${name} <input type="hidden" name="MarkerTypeIds" value="${id}" />
                                  <button type="button" class="btn-remove-pill" onclick="this.parentElement.remove()">&times;</button>`;
                container.appendChild(pill);
                t.classList.remove('selected');
            });
        }
    </script>
}
