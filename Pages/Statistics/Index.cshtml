@page
@model Board_Game_Software.Pages.Statistics.IndexModel
@{
    ViewData["Title"] = "Statistics";
    var maxMonth = Model.MonthlyActivity.Any() ? Model.MonthlyActivity.Max(m => m.Matches) : 0;
}

<style>
    .stats-shell { max-width: 1320px; }
    .stats-hero, .stats-card, .stats-table-wrap {
        border: 1px solid var(--bs-border-color);
        border-radius: 8px;
        background: var(--bs-body-tertiary);
    }
    .stats-kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: .75rem; }
    .stats-kpi { border: 1px solid var(--bs-border-color); border-radius: 8px; background: var(--bs-body-bg); }
    .kpi-value { font-size: 2rem; font-weight: 900; line-height: 1; }
    .cover-thumb { width: 48px; height: 48px; border-radius: 6px; object-fit: cover; background: var(--bs-secondary-bg); }
    .activity-bars { display: grid; grid-template-columns: repeat(auto-fit, minmax(86px, 1fr)); gap: .75rem; align-items: end; min-height: 180px; }
    .activity-column { display: grid; grid-template-rows: 1fr auto auto; gap: .4rem; min-height: 160px; }
    .activity-bar {
        align-self: end;
        border-radius: 6px 6px 2px 2px;
        min-height: 12px;
        background: linear-gradient(180deg, #20c997, #0dcaf0);
    }
    .record-table td, .record-table th { white-space: nowrap; }
    .record-table .name-cell { white-space: normal; min-width: 220px; }
    @@media (max-width: 767.98px) {
        .stats-kpis { grid-template-columns: 1fr 1fr; }
        .filters-grid { grid-template-columns: 1fr !important; }
    }
</style>

<div class="container-fluid py-4 stats-shell">
    <div class="stats-hero p-4 mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
            <div>
                <h1 class="fw-bold mb-1">Statistics</h1>
                <div class="text-secondary">A cleaner view of recent play, records, player bests, and activity trends.</div>
            </div>
            <form method="get" class="filters-grid d-grid gap-2" style="grid-template-columns: minmax(220px, 1.3fr) minmax(120px, .7fr) minmax(140px, .8fr) auto;">
                <select asp-for="SelectedPlayerId" asp-items="Model.PlayerList" class="form-select">
                    <option value="">All players</option>
                </select>
                <select asp-for="SelectedYear" asp-items="Model.YearList" class="form-select">
                    <option value="">All years</option>
                </select>
                <select asp-for="SelectedMonth" asp-items="Model.MonthList" class="form-select">
                    <option value="">All months</option>
                </select>
                <button class="btn btn-primary px-4" type="submit">
                    <i class="bi bi-funnel me-1"></i> Apply
                </button>
            </form>
        </div>
    </div>

    <div class="stats-kpis mb-4">
        <div class="stats-kpi p-3">
            <div class="text-secondary small text-uppercase fw-bold">Completed Matches</div>
            <div class="kpi-value">@Model.Summary.CompletedMatches</div>
        </div>
        <div class="stats-kpi p-3">
            <div class="text-secondary small text-uppercase fw-bold">Active Players</div>
            <div class="kpi-value">@Model.Summary.ActivePlayers</div>
        </div>
        <div class="stats-kpi p-3">
            <div class="text-secondary small text-uppercase fw-bold">Games Played</div>
            <div class="kpi-value">@Model.Summary.GamesPlayed</div>
        </div>
        <div class="stats-kpi p-3">
            <div class="text-secondary small text-uppercase fw-bold">Most Played</div>
            <div class="fw-bold fs-5 text-truncate">@Model.Summary.TopGame</div>
        </div>
        <div class="stats-kpi p-3">
            <div class="text-secondary small text-uppercase fw-bold">Most Wins</div>
            <div class="fw-bold fs-5 text-truncate">@Model.Summary.TopWinner</div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-7">
            <section class="stats-card p-3 h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 fw-bold mb-0">Recent Matches</h2>
                    <span class="badge rounded-pill text-bg-secondary">@Model.RecentMatches.Count shown</span>
                </div>

                @if (Model.RecentMatches.Any())
                {
                    <div class="d-grid gap-2">
                        @foreach (var match in Model.RecentMatches)
                        {
                            <a asp-page="/Match/Results" asp-route-id="@match.MatchId" class="d-flex align-items-center gap-3 p-2 rounded text-decoration-none border border-secondary-subtle">
                                <img src="/media/boardgame/front/@match.GameGid" class="cover-thumb" alt="@match.GameName cover" />
                                <div class="min-w-0 flex-grow-1">
                                    <div class="fw-bold text-body text-truncate">@match.GameName</div>
                                    <div class="small text-secondary text-truncate">Winner: @(string.IsNullOrWhiteSpace(match.Winners) ? "No winner recorded" : match.Winners)</div>
                                </div>
                                <div class="small text-secondary text-end">
                                    @(match.MatchDate?.ToString("dd MMM yyyy") ?? "No date")
                                </div>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="text-secondary py-5 text-center">No completed matches match these filters.</div>
                }
            </section>
        </div>

        <div class="col-xl-5">
            <section class="stats-card p-3 h-100">
                <h2 class="h5 fw-bold mb-3">Monthly Activity</h2>
                @if (Model.MonthlyActivity.Any())
                {
                    <div class="activity-bars">
                        @foreach (var month in Model.MonthlyActivity)
                        {
                            var height = maxMonth == 0 ? 0 : Math.Max(8, (int)Math.Round(month.Matches * 120m / maxMonth));
                            <div class="activity-column">
                                <div class="activity-bar" style="height: @(height)px;"></div>
                                <div class="fw-bold text-center">@month.Matches</div>
                                <div class="small text-secondary text-center">@month.Label</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-secondary py-5 text-center">No dated match activity yet.</div>
                }
            </section>
        </div>
    </div>

    @if (Model.SelectedPlayerId.HasValue)
    {
        <section class="stats-table-wrap p-3 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 fw-bold mb-0">Personal Bests @(string.IsNullOrWhiteSpace(Model.SelectedPlayerName) ? "" : "for " + Model.SelectedPlayerName)</h2>
                <span class="badge rounded-pill text-bg-info">@Model.PersonalBests.Count records</span>
            </div>
            @if (Model.PersonalBests.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle record-table mb-0">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th class="name-cell">Game</th>
                                <th class="text-end">Best Score</th>
                                <th class="text-end">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var best in Model.PersonalBests)
                            {
                                <tr>
                                    <td class="fw-bold">@(best.Rank == 0 ? "-" : "#" + best.Rank)</td>
                                    <td class="name-cell">
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="/media/boardgame/front/@best.GameGid" class="cover-thumb" alt="@best.GameName cover" />
                                            <span class="fw-semibold">@best.GameName</span>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold">@best.Score.ToString("N0")</td>
                                    <td class="text-end text-secondary">@(best.Date?.ToString("dd MMM yyyy") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-secondary py-4 text-center">This player has no point-game records in the selected range.</div>
            }
        </section>
    }

    <section class="stats-table-wrap p-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 fw-bold mb-0">Global High Scores</h2>
            <span class="badge rounded-pill text-bg-secondary">@Model.GlobalRecords.Count games</span>
        </div>
        @if (Model.GlobalRecords.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle record-table mb-0">
                    <thead>
                        <tr>
                            <th class="name-cell">Game</th>
                            <th>Record Holder</th>
                            <th class="text-end">High Score</th>
                            <th class="text-end">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in Model.GlobalRecords)
                        {
                            <tr>
                                <td class="name-cell">
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="/media/boardgame/front/@record.GameGid" class="cover-thumb" alt="@record.GameName cover" />
                                        <span class="fw-semibold">@record.GameName</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (record.PlayerGid.HasValue)
                                        {
                                            <img src="/media/player/@record.PlayerGid" class="cover-thumb rounded-circle" alt="@record.PlayerName" />
                                        }
                                        <span>@record.PlayerName</span>
                                    </div>
                                </td>
                                <td class="text-end fw-bold">@record.Score.ToString("N0")</td>
                                <td class="text-end text-secondary">@(record.Date?.ToString("dd MMM yyyy") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-secondary py-5 text-center">No point-game high scores match these filters.</div>
        }
    </section>
</div>
