@page
@model Board_Game_Software.Pages.Admin.Clubs.IndexModel
@{
    ViewData["Title"] = "Clubs";
}

<div class="container py-4 admin-shell">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3 mb-4">
        <div>
            <h1 class="fw-bold mb-1">Club Accounts</h1>
            <div class="text-secondary">Manage tenant accounts, ownership, and each club's working data.</div>
        </div>
        <a asp-page="/Admin/ManageUsers/Index" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-people me-1"></i> Users
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success rounded-4">@Model.StatusMessage</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger rounded-4"></div>
    }

    <section class="club-admin-layout">
        <div class="club-form-panel">
            <h2 class="h5 fw-bold mb-1">Create club account</h2>
            <div class="text-secondary small mb-3">A club account owns players, game nights, board game copies, and shelves. Plan can be chosen later.</div>
            <form method="post" asp-page-handler="SaveClub" class="vstack gap-3">
                <div>
                    <label asp-for="Input.ClubName" class="form-label">Club name</label>
                    <input asp-for="Input.ClubName" class="form-control" maxlength="120" />
                </div>
                <div>
                    <label asp-for="Input.Slug" class="form-label">Slug</label>
                    <input asp-for="Input.Slug" class="form-control" maxlength="80" placeholder="auto-created if blank" />
                </div>
                <div>
                    <label asp-for="Input.Description" class="form-label">Description</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="3" maxlength="500"></textarea>
                </div>
                <div>
                    <label asp-for="Input.ContactEmail" class="form-label">Contact email</label>
                    <input asp-for="Input.ContactEmail" class="form-control" maxlength="256" />
                </div>
                <div>
                    <label asp-for="Input.VenueName" class="form-label">Venue</label>
                    <input asp-for="Input.VenueName" class="form-control" maxlength="160" />
                </div>
                <div>
                    <label asp-for="Input.VenueAddress" class="form-label">Venue address</label>
                    <textarea asp-for="Input.VenueAddress" class="form-control" rows="2" maxlength="300"></textarea>
                </div>
                <div class="row g-2">
                    <div class="col-6">
                        <label asp-for="Input.Latitude" class="form-label">Latitude</label>
                        <input asp-for="Input.Latitude" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label asp-for="Input.Longitude" class="form-label">Longitude</label>
                        <input asp-for="Input.Longitude" class="form-control" />
                    </div>
                </div>
                <div>
                    <label asp-for="Input.OwnerUserId" class="form-label">Owner login</label>
                    <select asp-for="Input.OwnerUserId" asp-items="Model.UserOptions" class="form-select">
                        <option value="">Assign owner later</option>
                    </select>
                </div>
                <div class="form-check">
                    <input asp-for="Input.CreateStarterShelf" class="form-check-input" />
                    <label asp-for="Input.CreateStarterShelf" class="form-check-label">Create starter shelf</label>
                </div>
                <button type="submit" class="btn btn-primary rounded-pill">
                    <i class="bi bi-plus-lg me-1"></i> Create club
                </button>
            </form>
        </div>

        <div class="club-list">
            @if (!Model.Clubs.Any())
            {
                <div class="empty-state border rounded-3 p-4 text-center">
                    <i class="bi bi-building display-5 text-secondary"></i>
                    <h2 class="h5 fw-bold mt-3">No clubs yet</h2>
                    <p class="text-secondary mb-0">Create your first club, then add yourself as Owner.</p>
                </div>
            }

            @foreach (var club in Model.Clubs)
            {
                <article class="club-card">
                    <div class="club-card-header">
                        <div class="min-w-0">
                            <h2 class="h4 fw-bold mb-1 text-truncate">@club.ClubName</h2>
                            <div class="text-secondary small text-truncate">
                                /@club.Slug
                                @if (club.Owners.Any())
                                {
                                    <span class="mx-1">·</span>
                                    <span>Owner: @string.Join(", ", club.Owners.Take(2))</span>
                                }
                            </div>
                        </div>
                        <span class="badge rounded-pill @(club.Owners.Any() ? "text-bg-success" : "text-bg-warning")">
                            @(club.Owners.Any() ? "Active account" : "Needs owner")
                        </span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(club.Description))
                    {
                        <p class="text-secondary mb-3">@club.Description</p>
                    }

                    <div class="club-account-metrics mb-3">
                        <div class="club-account-metric">
                            <span class="metric-icon text-success"><i class="bi bi-people"></i></span>
                            <strong>@club.PlayerCount</strong>
                            <span>Players</span>
                        </div>
                        <div class="club-account-metric">
                            <span class="metric-icon text-primary"><i class="bi bi-dice-5"></i></span>
                            <strong>@club.BoardGameCount</strong>
                            <span>Games</span>
                        </div>
                        <div class="club-account-metric">
                            <span class="metric-icon text-info"><i class="bi bi-bookshelf"></i></span>
                            <strong>@club.ShelfCount</strong>
                            <span>Shelves</span>
                        </div>
                        <div class="club-account-metric">
                            <span class="metric-icon text-warning"><i class="bi bi-calendar-event"></i></span>
                            <strong>@club.GameNightCount</strong>
                            <span>Nights</span>
                        </div>
                    </div>

                    <div class="club-health mb-3">
                        <span class="club-health-chip @(club.HasContact ? "is-good" : "is-warning")">
                            <i class="bi @(club.HasContact ? "bi-check-circle" : "bi-exclamation-circle")"></i>
                            Contact
                        </span>
                        <span class="club-health-chip @(club.HasVenue ? "is-good" : "is-warning")">
                            <i class="bi @(club.HasVenue ? "bi-check-circle" : "bi-exclamation-circle")"></i>
                            Venue
                        </span>
                        <span class="club-health-chip @(club.HasMapLocation ? "is-good" : "is-muted")">
                            <i class="bi @(club.HasMapLocation ? "bi-geo-alt-fill" : "bi-geo-alt")"></i>
                            Map location
                        </span>
                        <span class="club-health-chip @(club.OpenGameNightCount > 0 ? "is-good" : "is-muted")">
                            <i class="bi bi-moon-stars"></i>
                            @club.OpenGameNightCount open night@(club.OpenGameNightCount == 1 ? "" : "s")
                        </span>
                    </div>

                    <div class="club-detail-grid mb-3">
                        <div>
                            <div class="small text-secondary text-uppercase fw-bold">Contact</div>
                            <div>@(club.ContactEmail ?? "Not set")</div>
                        </div>
                        <div>
                            <div class="small text-secondary text-uppercase fw-bold">Venue</div>
                            <div>@(club.VenueName ?? "Not set")</div>
                        </div>
                        <div>
                            <div class="small text-secondary text-uppercase fw-bold">Last game night</div>
                            <div>
                                @(club.LastGameNightDate?.ToString("dd MMM yyyy") ?? "No nights yet")
                            </div>
                        </div>
                    </div>

                    <div class="club-account-actions mb-3">
                        <form method="post" asp-page="/Clubs/Switch">
                            <input type="hidden" name="ClubId" value="@club.Id" />
                            <input type="hidden" name="ReturnUrl" value="/DataSetup/Players/Add" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-person-plus me-1"></i> First player
                            </button>
                        </form>
                        <form method="post" asp-page="/Clubs/Switch">
                            <input type="hidden" name="ClubId" value="@club.Id" />
                            <input type="hidden" name="ReturnUrl" value="/Browsing/BoardGames/Index?templates=true" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-dice-5 me-1"></i> Import games
                            </button>
                        </form>
                        <form method="post" asp-page="/Clubs/Switch">
                            <input type="hidden" name="ClubId" value="@club.Id" />
                            <input type="hidden" name="ReturnUrl" value="/DataSetup/Shelves/Add" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-bookshelf me-1"></i> First shelf
                            </button>
                        </form>
                        <form method="post" asp-page="/Clubs/Switch">
                            <input type="hidden" name="ClubId" value="@club.Id" />
                            <input type="hidden" name="ReturnUrl" value="/GameNight/Index" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-calendar-check me-1"></i> Nights
                            </button>
                        </form>
                    </div>

                    <details class="club-edit mb-3">
                        <summary class="btn btn-outline-secondary btn-sm rounded-pill">
                            <i class="bi bi-pencil me-1"></i> Edit club
                        </summary>
                        <form method="post" asp-page-handler="SaveClub" class="club-edit-form mt-3">
                            <input type="hidden" asp-for="Input.Id" value="@club.Id" />
                            <input asp-for="Input.ClubName" value="@club.ClubName" class="form-control" maxlength="120" aria-label="Club name" />
                            <input asp-for="Input.Slug" value="@club.Slug" class="form-control" maxlength="80" aria-label="Slug" />
                            <input asp-for="Input.ContactEmail" value="@club.ContactEmail" class="form-control" maxlength="256" aria-label="Contact email" />
                            <input asp-for="Input.VenueName" value="@club.VenueName" class="form-control" maxlength="160" aria-label="Venue name" />
                            <textarea asp-for="Input.Description" class="form-control" rows="2" maxlength="500" aria-label="Description">@club.Description</textarea>
                            <textarea asp-for="Input.VenueAddress" class="form-control" rows="2" maxlength="300" aria-label="Venue address">@club.VenueAddress</textarea>
                            <div class="row g-2">
                                <div class="col-6"><input asp-for="Input.Latitude" value="@club.Latitude" class="form-control" aria-label="Latitude" /></div>
                                <div class="col-6"><input asp-for="Input.Longitude" value="@club.Longitude" class="form-control" aria-label="Longitude" /></div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm rounded-pill">
                                <i class="bi bi-check-lg me-1"></i> Save
                            </button>
                        </form>
                    </details>

                    <div class="border-top pt-3">
                        <div class="d-flex justify-content-between align-items-center gap-3 mb-2">
                            <h3 class="h6 fw-bold mb-0">Members</h3>
                            <span class="badge text-bg-secondary rounded-pill">@club.Members.Count</span>
                        </div>

                        <div class="member-list mb-3">
                            @foreach (var member in club.Members)
                            {
                                <div class="member-row">
                                    <div class="min-w-0">
                                        <div class="fw-semibold text-truncate">@member.Email</div>
                                        <div class="small text-secondary">@member.Role</div>
                                    </div>
                                    <form method="post" asp-page-handler="RemoveMember">
                                        <input type="hidden" asp-for="MembershipId" value="@member.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill" aria-label="Remove member">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>

                        <form method="post" asp-page-handler="AddMember" class="add-member-form">
                            <input type="hidden" asp-for="ClubId" value="@club.Id" />
                            <select asp-for="UserId" asp-items="Model.UserOptions" class="form-select form-select-sm">
                                <option value="">Add user...</option>
                            </select>
                            <select asp-for="MembershipRole" asp-items="Model.RoleOptions" class="form-select form-select-sm"></select>
                            <button type="submit" class="btn btn-outline-success btn-sm rounded-pill">
                                <i class="bi bi-person-plus me-1"></i> Add
                            </button>
                        </form>
                    </div>
                </article>
            }
        </div>
    </section>
</div>
