@using Board_Game_Software.Models
@using Board_Game_Software.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject BoardGameDbContext BoardGameDbContext
@inject ICurrentClubService CurrentClubService

@{
    var isSignedIn = SignInManager.IsSignedIn(User);
    bool isAdmin = false;
    long? claimedPlayerId = null;
    CurrentClubContext currentClubContext = CurrentClubContext.Empty;

    if (isSignedIn)
    {
        var user = await UserManager.GetUserAsync(User);
        if (user != null)
        {
            isAdmin = await UserManager.IsInRoleAsync(user, "Admin");

            // Lookup claimed player ID for the quicklinks
            claimedPlayerId = BoardGameDbContext.Players
                .AsNoTracking()
                .Where(p => p.FkdboAspNetUsers == user.Id)
                .Select(p => (long?)p.Id)
                .FirstOrDefault();
        }

        currentClubContext = await CurrentClubService.GetCurrentClubAsync();
    }

    // Smart helper: checks if the title contains the keyword for active styling
    string IsActive(string keyword)
    {
        var title = ViewData["Title"]?.ToString() ?? "";
        return title.Contains(keyword, StringComparison.OrdinalIgnoreCase) ? "active" : "link-body-emphasis";
    }
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0d6efd" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Board Games" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <title>@ViewData["Title"] - Board Game Manager</title>

    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="~/images/app-icon.svg" />
    <link rel="apple-touch-icon" href="~/images/default-avatar.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script>
        const setTheme = (theme) => {
            document.documentElement.setAttribute('data-bs-theme', theme);
            localStorage.setItem('theme', theme);
        };
        const storedTheme = localStorage.getItem('theme') || 'light';
        setTheme(storedTheme);

        window.addEventListener('DOMContentLoaded', () => {
            const toggle = document.getElementById('themeToggle');
            if (localStorage.getItem('theme') === 'dark') {
                toggle.checked = true;
            }
            toggle.addEventListener('change', () => {
                const newTheme = toggle.checked ? 'dark' : 'light';
                setTheme(newTheme);
            });
        });
    </script>
</head>
<body>
    <header class="main-header">
        <nav class="navbar navbar-expand-sm bg-body">
            <div class="container-fluid">
                <button class="btn btn-outline-secondary nav-menu-button d-md-none me-2" type="button"
                        data-bs-toggle="offcanvas" data-bs-target="#sidebarNav"
                        aria-controls="sidebarNav" aria-label="Open navigation">
                    <i class="bi bi-list"></i>
                </button>
                <a class="navbar-brand fw-bold text-primary" asp-page="/Index">
                    <i class="bi bi-dice-5-fill me-2"></i><span class="brand-text">Board Game Manager</span>
                </a>
                <div class="navbar-tools d-flex align-items-center">
                    @if (currentClubContext.AvailableClubs.Count > 0)
                    {
                        <form method="post" asp-page="/Clubs/Switch" class="club-switcher me-3">
                            <input type="hidden" name="ReturnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                            <label class="visually-hidden" for="currentClubId">Current club</label>
                            <select id="currentClubId" name="ClubId" class="form-select form-select-sm" onchange="this.form.submit()">
                                @if (isAdmin)
                                {
                                    <option value="" selected="@currentClubContext.IsPlatformAdminMode">Platform Admin</option>
                                }
                                @foreach (var club in currentClubContext.AvailableClubs)
                                {
                                    <option value="@club.ClubId" selected="@(club.ClubId == currentClubContext.CurrentClubId)">@club.ClubName</option>
                                }
                            </select>
                        </form>
                    }

                    <div class="theme-toggle-wrap d-flex align-items-center me-3">
                        <i class="bi bi-sun-fill text-warning me-2"></i>

                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="themeToggle"
                                   style="cursor: pointer; width: 3em; height: 1.5em; margin-left: -2.5em;">
                        </div>

                        <i class="bi bi-moon-stars-fill text-primary ms-2"></i>
                    </div>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell">
            @* Sidebar Navigation *@
            <div class="offcanvas-md offcanvas-start sidebar-nav px-0"
                 tabindex="-1" id="sidebarNav" aria-labelledby="sidebarNavLabel">
                <div class="offcanvas-header d-md-none">
                    <h5 class="offcanvas-title" id="sidebarNavLabel">Navigation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#sidebarNav" aria-label="Close"></button>
                </div>
                <div class="p-3">
                    <h6 class="text-uppercase text-body-secondary fw-bold small mb-3 pt-2">Navigation</h6>
                    <ul class="nav nav-pills flex-column mb-4">
                        <li class="nav-item">
                            <a class="nav-link @IsActive("Home")" asp-page="/Index">
                                <i class="bi bi-house-door me-2"></i> Home
                            </a>
                        </li>

                        @if (claimedPlayerId.HasValue)
                        {
                            <li class="nav-item ps-3 mt-1">
                                <a class="nav-link py-1 small @IsActive("Player Details")"
                                   asp-page="/DataSetup/Players/Details" asp-route-id="@claimedPlayerId">
                                    <i class="bi bi-person-badge me-2"></i> My Profile
                                </a>
                            </li>
                            <li class="nav-item ps-3">
                                <a class="nav-link py-1 small @IsActive("Manage Top 10")"
                                   asp-page="/DataSetup/Players/ManageTopTen" asp-route-id="@claimedPlayerId">
                                    <i class="bi bi-trophy me-2"></i> My Top 10
                                </a>
                            </li>
                        }
                    </ul>

                    @if (isSignedIn)
                    {
                        <h6 class="text-uppercase text-body-secondary fw-bold small mb-3">Data Setup</h6>
                        <ul class="nav nav-pills flex-column mb-4">
                            <li><a class="nav-link @IsActive("Players")" asp-page="/DataSetup/Players/Index"><i class="bi bi-people me-2"></i> Players</a></li>
                            @if (isAdmin)
                            {
                                <li><a class="nav-link @IsActive("Markers")" asp-page="/DataSetup/Markers/Index"><i class="bi bi-tag me-2"></i> Markers</a></li>
                                <li><a class="nav-link @IsActive("Publishers")" asp-page="/DataSetup/Publishers/Index"><i class="bi bi-building me-2"></i> Publishers</a></li>
                            }
                            @if (isAdmin || currentClubContext.CanManageCurrentClub)
                            {
                                <li><a class="nav-link @IsActive("Shelves")" asp-page="/DataSetup/Shelves/Index"><i class="bi bi-bookshelf me-2"></i> Shelves</a></li>
                            }
                        </ul>
                    }

                    @* --- Browsing Section (Existing) --- *@
                    <h6 class="text-uppercase text-body-secondary fw-bold small mb-3">Browsing</h6>
                    <ul class="nav nav-pills flex-column mb-4">
                        <li><a class="nav-link @IsActive("Board Games")" asp-page="/Browsing/BoardGames/Index"><i class="bi bi-dice-5 me-2"></i> Board Games</a></li>
                        <li><a class="nav-link @IsActive("Game Night")" asp-page="/GameNight/Index"><i class="bi bi-calendar-check me-2"></i> Game Nights</a></li>
                    </ul>

                    @* --- NEW: Unified Analytics Section --- *@
                    <h6 class="text-uppercase text-body-secondary fw-bold small mb-3">Analytics</h6>
                    <ul class="nav nav-pills flex-column mb-4">
                        <li class="nav-item">
                            <a class="nav-link @IsActive("Statistics")" asp-page="/Statistics/Index">
                                <i class="bi bi-cpu me-2"></i> Global Stats
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @IsActive("Game Rankings")" asp-page="/Statistics/GameRankings">
                                <i class="bi bi-trophy me-2"></i> Game Rankings
                            </a>
                        </li>
                    </ul>

                    @* --- Admin Section (Existing) --- *@
                    @if (isAdmin)
                    {
                        <h6 class="text-uppercase text-danger-emphasis fw-bold small mb-3">Admin</h6>
                        <ul class="nav nav-pills flex-column">
                            <li><a class="nav-link @IsActive("Clubs")" asp-page="/Admin/Clubs/Index"><i class="bi bi-buildings me-2"></i> Clubs</a></li>
                            <li><a class="nav-link @IsActive("Users")" asp-page="/Admin/ManageUsers/Index"><i class="bi bi-gear me-2"></i> Manage Users</a></li>
                            <li><a class="nav-link @IsActive("Merge Players")" asp-page="/Admin/PlayerMerge/Index"><i class="bi bi-intersect me-2"></i> Merge Players</a></li>
                            <li><a class="nav-link @IsActive("Data Health")" asp-page="/Admin/DataHealth/Index"><i class="bi bi-clipboard2-pulse me-2"></i> Data Health</a></li>
                        </ul>
                    }
                </div>
            </div>

            @* Main Content Area *@
            <div class="app-main">
                <main role="main" class="app-content">
                    @RenderBody()
                </main>
            </div>
    </div>

    <div id="markerImageTooltip">
        <img id="tooltipImage" src="" alt="Preview" />
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js', { updateViaCache: 'none' })
                    .catch(error => console.warn('Service worker registration failed.', error));
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
